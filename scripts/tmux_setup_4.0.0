set -euo pipefail
IFS=$'\n\t'

# ─────────────────────────────────────────────────────────────────────────────
# STAŁE GLOBALNE
# ─────────────────────────────────────────────────────────────────────────────
readonly SCRIPT_VERSION="4.0.0"
readonly SCRIPT_NAME="SecFerro Termux Setup"
readonly LOG_FILE="${HOME}/.secferro_install.log"
readonly CONFIG_FILE="${HOME}/.secferro.conf"
readonly REQUIRED_STORAGE_MB=512

# ─────────────────────────────────────────────────────────────────────────────
# KOLORY I STYLE
# ─────────────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ─────────────────────────────────────────────────────────────────────────────
# FLAGI MODUŁÓW
# ─────────────────────────────────────────────────────────────────────────────
INSTALL_WEB=false
INSTALL_ANDROID=false
INSTALL_CYBER=false
INSTALL_FULLSTACK=false
INSTALL_TOR=false
INSTALL_DOCKER=false

DRY_RUN=false
SKIP_UI=false
VERBOSE=false
UNINSTALL=false

# ─────────────────────────────────────────────────────────────────────────────
# LOGOWANIE
# ─────────────────────────────────────────────────────────────────────────────
log() {
    local level="$1"; shift
    local msg="$*"
    local ts
    ts=$(date '+%Y-%m-%d %H:%M:%S')

    # Zapis do pliku (bez kolorów)
    echo "[$ts] [$level] $msg" >> "$LOG_FILE"

    # Wyjście na terminal (z kolorami)
    case "$level" in
        INFO)  echo -e "${BLUE}[*]${NC} $msg" ;;
        OK)    echo -e "${GREEN}[✓]${NC} $msg" ;;
        WARN)  echo -e "${YELLOW}[!]${NC} $msg" ;;
        ERROR) echo -e "${RED}[✗]${NC} $msg" >&2 ;;
        DEBUG) [[ "$VERBOSE" == true ]] && echo -e "${DIM}[D] $msg${NC}" ;;
        STEP)  echo -e "\n${CYAN}${BOLD}══ $msg ══${NC}" ;;
    esac
}

# ─────────────────────────────────────────────────────────────────────────────
# PASEK POSTĘPU
# ─────────────────────────────────────────────────────────────────────────────
progress_bar() {
    local current=$1
    local total=$2
    local label="${3:-Instalacja}"
    local width=40
    local filled=$(( current * width / total ))
    local empty=$(( width - filled ))
    local bar
    bar="$(printf '%0.s█' $(seq 1 $filled))$(printf '%0.s░' $(seq 1 $empty))"
    printf "\r${CYAN}  [%s] %d/%d ${DIM}%s${NC}" "$bar" "$current" "$total" "$label"
    [[ $current -eq $total ]] && echo ""
}

# ─────────────────────────────────────────────────────────────────────────────
# WYKONANIE POLECENIA (z obsługą dry-run i logowaniem)
# ─────────────────────────────────────────────────────────────────────────────
run_cmd() {
    local cmd="$*"
    log DEBUG "Wykonuję: $cmd"
    if [[ "$DRY_RUN" == true ]]; then
        echo -e "  ${DIM}[DRY-RUN]${NC} $cmd"
        return 0
    fi
    if ! eval "$cmd" >> "$LOG_FILE" 2>&1; then
        log ERROR "Polecenie nie powiodło się: $cmd"
        log WARN  "Sprawdź log: $LOG_FILE"
        return 1
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# BANER ASCII
# ─────────────────────────────────────────────────────────────────────────────
print_banner() {
    clear
    echo -e "${CYAN}${BOLD}"
    echo "  ██████╗███████╗ ██████╗███████╗███████╗██████╗ ██████╗  ██████╗ "
    echo "  ██╔════╝██╔════╝██╔════╝██╔════╝██╔════╝██╔══██╗██╔══██╗██╔═══██╗"
    echo "  ███████╗█████╗  ██║     █████╗  █████╗  ██████╔╝██████╔╝██║   ██║"
    echo "  ╚════██║██╔══╝  ██║     ██╔══╝  ██╔══╝  ██╔══██╗██╔══██╗██║   ██║"
    echo "  ███████║███████╗╚██████╗██║     ███████╗██║  ██║██║  ██║╚██████╔╝"
    echo "  ╚══════╝╚══════╝ ╚═════╝╚═╝     ╚══════╝╚═╝  ╚═╝╚═╝  ╚═╝ ╚═════╝"
    echo -e "${NC}"
    echo -e "  ${YELLOW}${BOLD}SECFERRO DIVISION SERIES${NC}  ${DIM}v${SCRIPT_VERSION}${NC}"
    echo -e "  ${DIM}github.com/Anonymousik  |  Anonymousik.is-a.dev${NC}"
    echo -e "  ${DIM}$(date '+%Y-%m-%d %H:%M')${NC}\n"
    echo -e "  ${DIM}Log: ${LOG_FILE}${NC}"
    echo -e "  ${PURPLE}────────────────────────────────────────────────────────${NC}\n"
}

# ─────────────────────────────────────────────────────────────────────────────
# POMOC
# ─────────────────────────────────────────────────────────────────────────────
print_help() {
    echo -e "${BOLD}UŻYCIE:${NC}"
    echo -e "  bash <(curl -sL Anonymousik.is-a.dev/scripts/tmux_setup) [OPCJE]\n"
    echo -e "${BOLD}OPCJE:${NC}"
    echo -e "  ${CYAN}--dev <moduły>${NC}   Moduły oddzielone przecinkiem:"
    echo -e "                   WebDev, Android, Cyber, Fullstack, Tor, Docker"
    echo -e "  ${CYAN}--dry-run${NC}        Symulacja — nic nie instaluje"
    echo -e "  ${CYAN}--no-ui${NC}          Pomija konfigurację Zsh / Oh-My-Zsh"
    echo -e "  ${CYAN}--verbose${NC}        Tryb debugowania"
    echo -e "  ${CYAN}--uninstall${NC}      Usuwa konfiguracje SecFerro"
    echo -e "  ${CYAN}--version${NC}        Wyświetla wersję skryptu"
    echo -e "  ${CYAN}--help${NC}           Ta wiadomość\n"
    echo -e "${BOLD}PRZYKŁADY:${NC}"
    echo -e "  # Web Developer:"
    echo -e "  ${DIM}bash <(curl -sL Anonymousik.is-a.dev/scripts/tmux_setup) --dev WebDev${NC}"
    echo -e "  # Pentester (Android + Cyber + Tor):"
    echo -e "  ${DIM}bash <(curl -sL Anonymousik.is-a.dev/scripts/tmux_setup) --dev Android,Cyber,Tor${NC}"
    echo -e "  # Pełna instalacja:"
    echo -e "  ${DIM}bash <(curl -sL Anonymousik.is-a.dev/scripts/tmux_setup) --dev WebDev,Android,Cyber,Fullstack,Tor,Docker${NC}"
    echo -e "  # Dry-run (symulacja):"
    echo -e "  ${DIM}bash <(curl -sL Anonymousik.is-a.dev/scripts/tmux_setup) --dry-run --dev Cyber${NC}\n"
}

# ─────────────────────────────────────────────────────────────────────────────
# PARSER ARGUMENTÓW
# ─────────────────────────────────────────────────────────────────────────────
parse_args() {
    while [[ "$#" -gt 0 ]]; do
        case $1 in
            --dev)
                [[ -z "${2:-}" ]] && { log ERROR "--dev wymaga listy modułów"; exit 1; }
                IFS=',' read -ra MODULES <<< "$2"
                for m in "${MODULES[@]}"; do
                    case $m in
                        WebDev)    INSTALL_WEB=true ;;
                        Android)   INSTALL_ANDROID=true ;;
                        Cyber)     INSTALL_CYBER=true ;;
                        Fullstack) INSTALL_FULLSTACK=true ;;
                        Tor)       INSTALL_TOR=true ;;
                        Docker)    INSTALL_DOCKER=true ;;
                        *)         log WARN "Nieznany moduł: '$m' — pomijam" ;;
                    esac
                done
                shift ;;
            --dry-run)  DRY_RUN=true ;;
            --no-ui)    SKIP_UI=true ;;
            --verbose)  VERBOSE=true ;;
            --uninstall) UNINSTALL=true ;;
            --version)  echo "$SCRIPT_NAME v$SCRIPT_VERSION"; exit 0 ;;
            --help|-h)  print_help; exit 0 ;;
            *)          log ERROR "Nieznana flaga: '$1'. Użyj --help."; exit 1 ;;
        esac
        shift
    done
}

# ─────────────────────────────────────────────────────────────────────────────
# WERYFIKACJA ŚRODOWISKA
# ─────────────────────────────────────────────────────────────────────────────
check_environment() {
    log STEP "Weryfikacja środowiska"

    # Termux?
    if [[ -z "${PREFIX:-}" ]] || [[ ! -d "$PREFIX" ]]; then
        log WARN "Środowisko może nie być Termuxem (PREFIX nie ustawiony)"
    else
        log OK "Wykryto Termux: $PREFIX"
    fi

    # Połączenie sieciowe
    if ping -c 1 -W 3 8.8.8.8 &>/dev/null; then
        log OK "Połączenie sieciowe: aktywne"
    else
        log ERROR "Brak połączenia sieciowego — sprawdź Wi-Fi/dane mobilne"
        exit 1
    fi

    # Dostępna przestrzeń dyskowa
    local available_mb
    available_mb=$(df "$HOME" | awk 'NR==2 {print int($4/1024)}')
    if [[ "$available_mb" -lt "$REQUIRED_STORAGE_MB" ]]; then
        log ERROR "Za mało miejsca: ${available_mb}MB dostępne, wymagane ${REQUIRED_STORAGE_MB}MB"
        exit 1
    fi
    log OK "Miejsce na dysku: ${available_mb}MB dostępne"

    # Wersja Bash
    log DEBUG "Bash: $BASH_VERSION"
}

# ─────────────────────────────────────────────────────────────────────────────
# BAZA SYSTEMU
# ─────────────────────────────────────────────────────────────────────────────
setup_base() {
    log STEP "Aktualizacja systemu"
    run_cmd "pkg update -y && pkg upgrade -y"
    run_cmd "pkg install -y git curl wget zsh nano ncurses-utils openssh tmux"
    log OK "Pakiety bazowe zainstalowane"
}

# ─────────────────────────────────────────────────────────────────────────────
# MODUŁ: WebDev
# ─────────────────────────────────────────────────────────────────────────────
install_web() {
    log STEP "Moduł: WebDev"
    local pkgs=("nodejs-lts" "yarn" "php" "python" "python-pip" "deno")
    local total=${#pkgs[@]}
    for i in "${!pkgs[@]}"; do
        progress_bar $(( i + 1 )) "$total" "${pkgs[$i]}"
        run_cmd "pkg install -y ${pkgs[$i]}"
    done

    # npm globals
    run_cmd "npm install -g typescript eslint prettier vite"
    run_cmd "pip install flask fastapi uvicorn httpx --quiet"

    log OK "WebDev: Node.js LTS, Yarn, PHP, Python, Deno, TypeScript, Vite"
}

# ─────────────────────────────────────────────────────────────────────────────
# MODUŁ: Android Dev
# ─────────────────────────────────────────────────────────────────────────────
install_android() {
    log STEP "Moduł: Android Dev"
    run_cmd "pkg install -y openjdk-17 gradle kotlin"
    # Opcjonalnie: aapt, adb (jeśli dostępne w repo)
    run_cmd "pkg install -y aapt" || log WARN "aapt niedostępny — pomijam"
    log OK "Android: OpenJDK 17, Gradle, Kotlin"
}

# ─────────────────────────────────────────────────────────────────────────────
# MODUŁ: CyberSecurity
# ─────────────────────────────────────────────────────────────────────────────
install_cyber() {
    log STEP "Moduł: CyberSecurity"
    local pkgs=(
        "nmap" "sqlmap" "hydra" "openssl-tool"
        "whatweb" "dnsutils" "net-tools" "whois"
        "aircrack-ng" "tcpdump"
    )
    local total=${#pkgs[@]}
    for i in "${!pkgs[@]}"; do
        progress_bar $(( i + 1 )) "$total" "${pkgs[$i]}"
        run_cmd "pkg install -y ${pkgs[$i]}" || log WARN "Pominięto: ${pkgs[$i]}"
    done

    # Python security tools
    run_cmd "pip install scapy impacket pwntools --quiet" || \
        log WARN "Niektóre Python security tools niedostępne"

    # Nikto (web vulnerability scanner)
    if [[ ! -d "$HOME/nikto" ]]; then
        run_cmd "git clone --depth=1 https://github.com/sullo/nikto $HOME/nikto"
        echo "alias nikto='perl $HOME/nikto/program/nikto.pl'" >> ~/.zshrc
    fi

    log OK "Cyber: nmap, sqlmap, hydra, nikto, scapy, pwntools i więcej"
}

# ─────────────────────────────────────────────────────────────────────────────
# MODUŁ: Fullstack / Compiled Languages
# ─────────────────────────────────────────────────────────────────────────────
install_fullstack() {
    log STEP "Moduł: Fullstack (Compiled)"
    run_cmd "pkg install -y clang make cmake rust golang lua54"
    run_cmd "cargo install cargo-watch" || log WARN "cargo-watch: błąd instalacji"
    log OK "Fullstack: Rust, Go, C/C++, CMake, Lua"
}

# ─────────────────────────────────────────────────────────────────────────────
# MODUŁ: Tor + ProxyChains (Anonimowość)
# ─────────────────────────────────────────────────────────────────────────────
install_tor() {
    log STEP "Moduł: Tor & ProxyChains"
    run_cmd "pkg install -y tor proxychains-ng"

    # Konfiguracja ProxyChains (dynamiczny łańcuch przez Tor)
    local pc_conf="${PREFIX}/etc/proxychains.conf"
    if [[ -f "$pc_conf" ]]; then
        run_cmd "sed -i 's/^strict_chain/#strict_chain/' $pc_conf"
        run_cmd "sed -i 's/^#dynamic_chain/dynamic_chain/' $pc_conf"
        # Dodaj wpis SOCKS5 Tora jeśli nie istnieje
        grep -q "socks5 127.0.0.1 9050" "$pc_conf" || \
            echo "socks5 127.0.0.1 9050" >> "$pc_conf"
        log OK "ProxyChains skonfigurowany (dynamic chain → Tor SOCKS5:9050)"
    fi

    # Alias do uruchomienia Tora w tle
    cat >> ~/.zshrc << 'EOF'

# SecFerro: Tor helpers
alias tor-start='tor &>/dev/null & echo "[SecFerro] Tor uruchomiony (PID: $!)"'
alias tor-stop='pkill tor && echo "[SecFerro] Tor zatrzymany"'
alias tor-check='curl --socks5-hostname 127.0.0.1:9050 https://check.torproject.org/api/ip'
alias prox='proxychains4 -q'
EOF

    log OK "Tor: zainstalowany | użyj 'tor-start', 'prox <komenda>'"
}

# ─────────────────────────────────────────────────────────────────────────────
# MODUŁ: Docker (Proot-Distro jako alternatywa)
# ─────────────────────────────────────────────────────────────────────────────
install_docker() {
    log STEP "Moduł: Docker / Proot-Distro"
    log WARN "Docker daemon nie jest wspierany natywnie w Termuxie."
    log INFO "Instaluję proot-distro (Ubuntu/Debian w kontenerze proot)"
    run_cmd "pkg install -y proot-distro"

    # Instalacja Ubuntu jeśli nie istnieje
    if ! proot-distro list 2>/dev/null | grep -q "ubuntu"; then
        run_cmd "proot-distro install ubuntu"
        log OK "Ubuntu (proot) zainstalowany"
    else
        log OK "Ubuntu (proot) już zainstalowany"
    fi

    cat >> ~/.zshrc << 'EOF'

# SecFerro: Proot-Distro helpers
alias ubuntu='proot-distro login ubuntu'
alias dlist='proot-distro list'
EOF

    log OK "Proot-Distro: użyj 'ubuntu' aby wejść do środowiska Ubuntu"
}

# ─────────────────────────────────────────────────────────────────────────────
# KONFIGURACJA UI (Zsh + Oh-My-Zsh + Plugins + MOTD)
# ─────────────────────────────────────────────────────────────────────────────
setup_ui() {
    log STEP "Konfiguracja środowiska Zsh"

    # Instalacja Oh-My-Zsh
    if [[ ! -d "$HOME/.oh-my-zsh" ]]; then
        log INFO "Instalacja Oh-My-Zsh..."
        run_cmd 'sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended'
    else
        log OK "Oh-My-Zsh już zainstalowany"
    fi

    # Zsh plugins (zsh-autosuggestions, zsh-syntax-highlighting)
    local ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"
    if [[ ! -d "$ZSH_CUSTOM/plugins/zsh-autosuggestions" ]]; then
        run_cmd "git clone --depth=1 https://github.com/zsh-users/zsh-autosuggestions \
            $ZSH_CUSTOM/plugins/zsh-autosuggestions"
    fi
    if [[ ! -d "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting" ]]; then
        run_cmd "git clone --depth=1 https://github.com/zsh-users/zsh-syntax-highlighting \
            $ZSH_CUSTOM/plugins/zsh-syntax-highlighting"
    fi

    # Powerlevel10k theme
    if [[ ! -d "$ZSH_CUSTOM/themes/powerlevel10k" ]]; then
        log INFO "Instalacja motywu Powerlevel10k..."
        run_cmd "git clone --depth=1 https://github.com/romkatv/powerlevel10k \
            $ZSH_CUSTOM/themes/powerlevel10k"
    fi

    # Nadpisanie .zshrc (zachowując ewentualne wcześniejsze dodatki)
    local zshrc="$HOME/.zshrc"
    if [[ -f "$zshrc" ]]; then
        cp "$zshrc" "${zshrc}.bak_$(date +%s)"
        log DEBUG "Backup .zshrc zapisany"
    fi

    cat > "$zshrc" << 'ZSHRC'
# ── SecFerro .zshrc ─────────────────────────────────────────────────────────
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"

plugins=(
    git
    zsh-autosuggestions
    zsh-syntax-highlighting
    colored-man-pages
    command-not-found
    sudo
)

source $ZSH/oh-my-zsh.sh

# Historя
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_DUPS
setopt SHARE_HISTORY

# Aliasy ogólne
alias ll='ls -lAhF --color=auto'
alias la='ls -A'
alias cls='clear'
alias update='pkg update -y && pkg upgrade -y'
alias myip='curl -s https://ipinfo.io/ip'
alias ports='ss -tuln'
alias cpu='top -bn1 | grep "Cpu(s)"'

# Funkcja MOTD — wywoływana automatycznie
secferro_motd() {
    echo -e "\033[0;36m\033[1m"
    echo "  ██████╗███████╗ ██████╗███████╗███████╗██████╗ ██████╗  ██████╗ "
    echo "  ██╔════╝██╔════╝██╔════╝██╔════╝██╔════╝██╔══██╗██╔══██╗██╔═══██╗"
    echo "  ███████╗█████╗  ██║     █████╗  █████╗  ██████╔╝██████╔╝██║   ██║"
    echo "  ╚════██║██╔══╝  ██║     ██╔══╝  ██╔══╝  ██╔══██╗██╔══██╗██║   ██║"
    echo "  ███████║███████╗╚██████╗██║     ███████╗██║  ██║██║  ██║╚██████╔╝"
    echo "  ╚══════╝╚══════╝ ╚═════╝╚═╝     ╚══════╝╚═╝  ╚═╝╚═╝  ╚═╝ ╚═════╝"
    echo -e "\033[0m\033[1;33m  SECFERRO DIVISION SERIES\033[0m"
    printf "  \033[2m%s | %s | uptime: %s\033[0m\n" \
        "$(date '+%Y-%m-%d %H:%M')" \
        "$(uname -r 2>/dev/null || echo 'Termux')" \
        "$(uptime -p 2>/dev/null || echo 'n/a')"
    echo ""
}
secferro_motd
ZSHRC

    # Wyciszenie domyślnego MOTD systemu
    touch ~/.hushlogin

    log OK "Zsh + Oh-My-Zsh + Powerlevel10k + plugins skonfigurowane"
}

# ─────────────────────────────────────────────────────────────────────────────
# GENEROWANIE KLUCZA SSH (opcjonalne)
# ─────────────────────────────────────────────────────────────────────────────
setup_ssh_key() {
    local key="$HOME/.ssh/id_ed25519"
    if [[ ! -f "$key" ]]; then
        log INFO "Generowanie klucza SSH (ed25519)..."
        run_cmd "mkdir -p ~/.ssh && chmod 700 ~/.ssh"
        run_cmd "ssh-keygen -t ed25519 -C 'secferro@termux' -f $key -N ''"
        log OK "Klucz SSH wygenerowany: $key"
        log INFO "Publiczny klucz:"
        [[ "$DRY_RUN" == false ]] && cat "${key}.pub"
    else
        log OK "Klucz SSH już istnieje: $key"
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# ZAPIS KONFIGURACJI INSTALACJI
# ─────────────────────────────────────────────────────────────────────────────
save_config() {
    {
        echo "# SecFerro Install Config — $(date)"
        echo "VERSION=$SCRIPT_VERSION"
        echo "INSTALL_WEB=$INSTALL_WEB"
        echo "INSTALL_ANDROID=$INSTALL_ANDROID"
        echo "INSTALL_CYBER=$INSTALL_CYBER"
        echo "INSTALL_FULLSTACK=$INSTALL_FULLSTACK"
        echo "INSTALL_TOR=$INSTALL_TOR"
        echo "INSTALL_DOCKER=$INSTALL_DOCKER"
    } > "$CONFIG_FILE"
    log DEBUG "Konfiguracja zapisana: $CONFIG_FILE"
}

# ─────────────────────────────────────────────────────────────────────────────
# DEINSTALACJA
# ─────────────────────────────────────────────────────────────────────────────
do_uninstall() {
    log STEP "Deinstalacja SecFerro"
    log WARN "Usuwa: Oh-My-Zsh, konfiguracje, aliasy SecFerro"
    read -rp "$(echo -e "${RED}Kontynuować? [t/N]:${NC} ")" confirm
    [[ "${confirm,,}" != "t" ]] && { log INFO "Anulowano."; exit 0; }
    [[ -d "$HOME/.oh-my-zsh" ]] && rm -rf "$HOME/.oh-my-zsh" && log OK "Oh-My-Zsh usunięty"
    [[ -f "$HOME/.zshrc" ]] && rm -f "$HOME/.zshrc" && log OK ".zshrc usunięty"
    [[ -f "$CONFIG_FILE" ]] && rm -f "$CONFIG_FILE"
    [[ -d "$HOME/nikto" ]] && rm -rf "$HOME/nikto" && log OK "nikto usunięty"
    log OK "Deinstalacja zakończona. Zaloguj się ponownie."
    exit 0
}

# ─────────────────────────────────────────────────────────────────────────────
# INTERAKTYWNE MENU (gdy brak argumentów)
# ─────────────────────────────────────────────────────────────────────────────
interactive_menu() {
    echo -e "${BOLD}WYBIERZ MODUŁY INSTALACJI:${NC}\n"
    echo -e "  ${CYAN}1)${NC} WebDev      — Node.js LTS, Yarn, PHP, Python, Deno, TypeScript, Vite"
    echo -e "  ${CYAN}2)${NC} Android     — OpenJDK 17, Gradle, Kotlin"
    echo -e "  ${CYAN}3)${NC} CyberSec    — nmap, sqlmap, hydra, nikto, scapy, pwntools"
    echo -e "  ${CYAN}4)${NC} Fullstack   — Rust, Go, C/C++, CMake, Lua"
    echo -e "  ${CYAN}5)${NC} Tor+Proxy   — Tor, ProxyChains (tryb dynamiczny)"
    echo -e "  ${CYAN}6)${NC} Docker/Proot— proot-distro (Ubuntu w kontenerze)"
    echo -e "  ${CYAN}7)${NC} Wszystko    — Pełna instalacja (1–6)"
    echo -e "  ${CYAN}0)${NC} Wyjście\n"

    read -rp "$(echo -e "${BOLD}Wybór [0-7, możesz podać kilka np. 1,3,5]:${NC} ")" raw_choice
    IFS=',' read -ra choices <<< "$raw_choice"

    for c in "${choices[@]}"; do
        case $c in
            1) INSTALL_WEB=true ;;
            2) INSTALL_ANDROID=true ;;
            3) INSTALL_CYBER=true ;;
            4) INSTALL_FULLSTACK=true ;;
            5) INSTALL_TOR=true ;;
            6) INSTALL_DOCKER=true ;;
            7) INSTALL_WEB=true; INSTALL_ANDROID=true; INSTALL_CYBER=true
               INSTALL_FULLSTACK=true; INSTALL_TOR=true; INSTALL_DOCKER=true ;;
            0) log INFO "Wychodzę."; exit 0 ;;
            *) log WARN "Nieznany wybór: '$c'" ;;
        esac
    done

    echo ""
}

# ─────────────────────────────────────────────────────────────────────────────
# PODSUMOWANIE INSTALACJI
# ─────────────────────────────────────────────────────────────────────────────
print_summary() {
    local installed=()
    [[ "$INSTALL_WEB" == true ]]       && installed+=("WebDev")
    [[ "$INSTALL_ANDROID" == true ]]   && installed+=("Android")
    [[ "$INSTALL_CYBER" == true ]]     && installed+=("CyberSec")
    [[ "$INSTALL_FULLSTACK" == true ]] && installed+=("Fullstack")
    [[ "$INSTALL_TOR" == true ]]       && installed+=("Tor+Proxy")
    [[ "$INSTALL_DOCKER" == true ]]    && installed+=("Docker/Proot")

    echo -e "\n${CYAN}${BOLD}╔═══════════════════════════════════════╗"
    echo    "║       INSTALACJA ZAKOŃCZONA ✓         ║"
    echo -e "╚═══════════════════════════════════════╝${NC}\n"
    echo -e "  ${BOLD}Zainstalowane moduły:${NC}"
    for m in "${installed[@]}"; do
        echo -e "    ${GREEN}✓${NC} $m"
    done
    echo -e "\n  ${BOLD}Następne kroki:${NC}"
    echo -e "    ${YELLOW}exec zsh${NC}       → Wejdź do nowej powłoki"
    echo -e "    ${YELLOW}p10k configure${NC} → Skonfiguruj motyw Powerlevel10k"
    [[ "$INSTALL_TOR" == true ]] && \
        echo -e "    ${YELLOW}tor-start${NC}      → Uruchom Tor (daemon)"
    [[ "$INSTALL_DOCKER" == true ]] && \
        echo -e "    ${YELLOW}ubuntu${NC}         → Wejdź do środowiska Ubuntu"
    echo -e "\n  ${DIM}Log instalacji: $LOG_FILE${NC}\n"
}

# ─────────────────────────────────────────────────────────────────────────────
# GŁÓWNA LOGIKA
# ─────────────────────────────────────────────────────────────────────────────
main() {
    # Inicjalizacja logu
    mkdir -p "$(dirname "$LOG_FILE")"
    echo "# SecFerro Install Log — $(date)" > "$LOG_FILE"

    print_banner

    # Parsowanie argumentów
    if [[ "$#" -gt 0 ]]; then
        parse_args "$@"
    fi

    # Deinstalacja
    [[ "$UNINSTALL" == true ]] && do_uninstall

    # Tryb interaktywny jeśli nie podano --dev
    if ! $INSTALL_WEB && ! $INSTALL_ANDROID && ! $INSTALL_CYBER && \
       ! $INSTALL_FULLSTACK && ! $INSTALL_TOR && ! $INSTALL_DOCKER; then
        interactive_menu
    fi

    # Dry-run info
    [[ "$DRY_RUN" == true ]] && log WARN "TRYB DRY-RUN — żadne pakiety nie zostaną zainstalowane"

    # Weryfikacja środowiska
    check_environment

    # Instalacja
    setup_base
    $INSTALL_WEB       && install_web
    $INSTALL_ANDROID   && install_android
    $INSTALL_CYBER     && install_cyber
    $INSTALL_FULLSTACK && install_fullstack
    $INSTALL_TOR       && install_tor
    $INSTALL_DOCKER    && install_docker

    # UI (jeśli nie pominięte)
    [[ "$SKIP_UI" == false ]] && setup_ui

    # SSH key
    setup_ssh_key

    # Zapis konfiguracji
    [[ "$DRY_RUN" == false ]] && save_config

    print_summary
}

main "$@"
