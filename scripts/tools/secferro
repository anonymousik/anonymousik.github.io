        4) sf_ros_cmd "/tool ip-scan interface=ether1 duration=5s" ;;
        5) sf_fix_hosts ;;
        6) ip route 2>/dev/null || route 2>/dev/null ;;
        7) traceroute 8.8.8.8 2>/dev/null || c_warn "traceroute niedostępny" ;;
        8) sf_net_report_full ;;
        0) return ;;
    esac
