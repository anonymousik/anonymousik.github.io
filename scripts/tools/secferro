sf_gen_init_rsc() {
    c_hdr "GENEROWANIE init.rsc RouterOS"
    local out="${SF_HOME}/conf/init.rsc"
    mkdir -p "$(dirname "$out")"
    cat > "$out" <<EOF
# SecFerro — RouterOS init.rsc
# Wygenerowano przez SecFerro v2.0 dnia $(date)
# Wysyłaj przez: sfstart → opcja 3 (wysłanie init.rsc)

# ── Tożsamość ─────────────────────────────────────────────────────────────────
/system identity set name=SecFerro-Router

# ── NTP ───────────────────────────────────────────────────────────────────────
/system ntp client set enabled=yes primary-ntp=216.239.35.0 secondary-ntp=216.239.35.4

# ── DNS ───────────────────────────────────────────────────────────────────────
/ip dns set servers=1.1.1.1,8.8.8.8 allow-remote-requests=yes

# ── Email relay → SecFerro host ──────────────────────────────────────────────
/tool e-mail set address=${NET_HOST_GW} port=25 start-tls=no \\
  from=router@${DNS_DOMAIN} user=router password=secferro

# ── SNMP ─────────────────────────────────────────────────────────────────────
/snmp set enabled=yes src-address=127.0.0.1

# ── Firewall — podstawowy ─────────────────────────────────────────────────────
/ip firewall filter
add chain=input   action=accept connection-state=established,related comment="Accept established"
add chain=input   action=accept protocol=icmp                         comment="Accept ICMP"
add chain=input   action=accept src-address=${NET_SUBNET}             comment="Accept local subnet"
add chain=input   action=drop                                          comment="Drop everything else"

add chain=forward action=accept connection-state=established,related  comment="Accept established fwd"
add chain=forward action=drop                                          comment="Drop unestablished fwd"

# ── Scheduler — test email po starcie ────────────────────────────────────────
/system scheduler add name=boot-email-test interval=5m on-event=\\
  "/tool e-mail send to=${MAIL_ALERT_TO:-admin@example.com} subject=\\\"RouterOS started\\\" \\
   body=\\\"SecFerro RouterOS uruchomiony: [/system resource get uptime]\\\"" \\
  start-time=startup

# ── Netwatch — monitoring internetu ──────────────────────────────────────────
/tool netwatch
add host=8.8.8.8 interval=1m \\
  up-script="/log info message=\\\"LINK UP: internet dostępny\\\"" \\
  down-script="/tool e-mail send to=${MAIL_ALERT_TO:-admin@example.com} \\
    subject=\\\"[ALERT] Internet DOWN!\\\" body=\\\"SecFerro: 8.8.8.8 niedostępny\\\""

# ── Logi ─────────────────────────────────────────────────────────────────────
/system logging
add topics=info    action=memory
add topics=warning action=memory
add topics=error   action=memory

:log info "SecFerro init.rsc załadowany pomyślnie"
EOF
    c_ok "init.rsc wygenerowany: $out"
}

