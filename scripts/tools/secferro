    c_hdr "SMTP / EMAIL PIPELINE"
    echo
    echo -e "  ${D}Architektura:  RouterOS → 192.168.168.1:25 → msmtpd:2526 → Gmail/SMTP${R}"
    echo
    local relay_s; sf_relay_running && relay_s="${GRN}AKTYWNY${R}" || relay_s="${RED}WYŁĄCZONY${R}"
    echo -e "  Status relay: ${relay_s}"
    echo
    echo -e "  ${GRN}${B}1.${R} Uruchom relay SMTP (msmtpd → :2526)"
    echo -e "  ${RED}${B}2.${R} Zatrzymaj relay SMTP"
    echo -e "  ${BLU}${B}3.${R} Test wysyłki (RouterOS → Gmail)"
    echo -e "  ${YLW}${B}4.${R} Konfiguruj dane konta zewnętrznego"
    echo -e "  ${CYN}${B}5.${R} Pokaż .msmtprc"
    echo -e "  ${MAG}${B}6.${R} Generuj .msmtprc automatycznie"
    echo -e "  ${D}${B}7.${R} Debug relay (verbose log)"
    echo -e "  ${D}${B}8.${R} Sprawdź logi email"
    echo -e "  ${D}${B}0.${R} Wróć"
    echo
    read -rp "  $(echo -e "${CYN}Wybór > ${R}")" ch
