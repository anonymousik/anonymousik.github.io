sf_smtp_configure() {
    c_hdr "KONFIGURACJA KONTA SMTP ZEWNĘTRZNEGO"
    c_info "Te dane zostaną zapisane w ~/.msmtprc"
    echo
    echo -e "  ${D}(Puste = pozostaw bez zmian)${R}"
    echo

    read -rp "  Host SMTP [${MAIL_RELAY_HOST}]: " inp
    [[ -n "$inp" ]] && MAIL_RELAY_HOST="$inp"

    read -rp "  Port [${MAIL_RELAY_PORT}]: " inp
    [[ -n "$inp" ]] && MAIL_RELAY_PORT="$inp"

    read -rp "  User/email [${MAIL_RELAY_USER}]: " inp
    [[ -n "$inp" ]] && MAIL_RELAY_USER="$inp"

    read -rsp "  Hasło (ukryte) [****]: " inp; echo
    [[ -n "$inp" ]] && MAIL_RELAY_PASS="$inp"

    read -rp "  Alert TO (odbiorca) [${MAIL_ALERT_TO}]: " inp
    [[ -n "$inp" ]] && MAIL_ALERT_TO="$inp"

    sf_smtp_generate_config
    sf_conf_save
}

sf_smtp_generate_config() {
    c_hdr "GENEROWANIE ~/.msmtprc"
    local msmtp_rc="$HOME/.msmtprc"

    if [[ -z "$MAIL_RELAY_USER" ]]; then
        c_err "Brak skonfigurowanego konta SMTP. Uruchom opcję 4 najpierw."
        return 1
    fi

    cat > "$msmtp_rc" <<EOF
# ~/.msmtprc — wygenerowany przez SecFerro v2.0
# Plik konfiguracyjny msmtp — client SMTP relay

defaults
    auth           on
    tls            on
    tls_starttls   on
    tls_trust_file /data/data/com.termux/files/usr/etc/tls/cert.pem
    logfile        ${SF_LOG_DIR}/msmtp.log
    syslog         off

# Konto domyślne (relay dla RouterOS)
account        secferro-relay
host           ${MAIL_RELAY_HOST}
port           ${MAIL_RELAY_PORT}
from           ${MAIL_FROM}
user           ${MAIL_RELAY_USER}
password       ${MAIL_RELAY_PASS}

# Konto alert (bezpośrednie wysyłki alertów z Termux)
account        alert
host           ${MAIL_RELAY_HOST}
port           ${MAIL_RELAY_PORT}
from           ${MAIL_FROM}
user           ${MAIL_RELAY_USER}
password       ${MAIL_RELAY_PASS}

account default : secferro-relay
EOF
    chmod 600 "$msmtp_rc"
    c_ok ".msmtprc wygenerowany: $msmtp_rc"
    c_dim "Uprawnienia: 600 (prywatny)"
}

sf_smtp_show_config() {
    c_hdr "AKTUALNY ~/.msmtprc"
    if [[ -f "$HOME/.msmtprc" ]]; then
        # Ukryj hasło
        sed 's/^password.*/password       [UKRYTE]/' "$HOME/.msmtprc"
    else
        c_warn "Brak ~/.msmtprc — uruchom opcję 6 aby wygenerować"
    fi
}

sf_smtp_show_logs() {
