#!/data/data/com.termux/files/usr/bin/bash
# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  SecFerro v2.0 — RouterOS-on-Termux Management Suite                   ║
# ║  Autor: SecFerro Division  |  Platforma: Termux/Android + QEMU TCG     ║
# ╠══════════════════════════════════════════════════════════════════════════╣
# ║  ARCHITEKTURA SIECI QEMU (user/slirp):                                 ║
# ║    Host (Termux):  127.0.0.1  +  tap: 192.168.168.1                   ║
# ║    RouterOS VM:    192.168.168.3   (DHCP)                              ║
# ║    Port forwards:  2222→22(SSH) | 2525→25(SMTP-in) | 8291→8291(Winbox)║
# ║    SMTP relay OUT: guestfwd 192.168.168.1:25 → 127.0.0.1:2526        ║
# ╚══════════════════════════════════════════════════════════════════════════╝
set -euo pipefail

# ─────────────────────────── CONFIG ──────────────────────────────────────────
SF_HOME="${SF_HOME:-$HOME/secferro}"
SF_CONF="${SF_HOME}/conf/secferro.conf"
SF_LOG_DIR="${SF_HOME}/logs"
SF_PID_FILE="${SF_HOME}/run/qemu.pid"
SF_DISK="${SF_HOME}/vm/routeros.img"

# Załaduj konfigurację jeśli istnieje
[[ -f "$SF_CONF" ]] && source "$SF_CONF"

# Domyślne wartości (nadpisywane przez secferro.conf)
: "${VM_RAM:=256}"
: "${VM_DISK:=$SF_DISK}"
: "${VM_ARCH:=x86_64}"
: "${NET_SUBNET:=192.168.168.0/24}"
: "${NET_HOST_GW:=192.168.168.1}"          # IP hosta widoczne z VM
: "${NET_VM_IP:=192.168.168.3}"             # IP RouterOS
: "${PORT_SSH:=2222}"                        # Host→VM SSH
: "${PORT_SMTP_IN:=2525}"                    # Host→VM SMTP (RouterOS odbieranie)
: "${PORT_SMTP_RELAY:=2526}"                 # Host lokalny relay OUT (VM→Host→Internet)
: "${PORT_WINBOX:=8291}"
: "${PORT_API:=8728}"
: "${ROS_USER:=admin}"
: "${ROS_PASS:=}"
: "${MAIL_FROM:=router@secferro.lan}"
: "${MAIL_RELAY_HOST:=smtp.gmail.com}"
: "${MAIL_RELAY_PORT:=587}"
: "${MAIL_RELAY_USER:=}"
: "${MAIL_RELAY_PASS:=}"
: "${MAIL_ALERT_TO:=}"
: "${DNS_DOMAIN:=secferro.lan}"

# ─────────────────────────── KOLORY ──────────────────────────────────────────
R='\033[0m'; B='\033[1m'; D='\033[2m'
RED='\033[91m'; GRN='\033[92m'; YLW='\033[93m'
BLU='\033[94m'; MAG='\033[95m'; CYN='\033[96m'
BGRD='\033[41m'; BGRN='\033[42m'

c_ok()   { echo -e "${GRN}${B}[✓]${R} $*"; }
c_err()  { echo -e "${RED}${B}[✗]${R} $*"; }
c_warn() { echo -e "${YLW}${B}[!]${R} $*"; }
c_info() { echo -e "${BLU}[i]${R} $*"; }
c_dim()  { echo -e "${D}    └─ $*${R}"; }
c_fix()  { echo -e "${MAG}${B}[🔧]${R} $*"; }
c_hdr()  { echo -e "\n${CYN}${B}══ $* ══${R}\n"; }

# ─────────────────────────── NARZĘDZIA ───────────────────────────────────────
sf_vm_running() {
    [[ -f "$SF_PID_FILE" ]] || return 1
    local pid; pid=$(cat "$SF_PID_FILE" 2>/dev/null) || return 1
    kill -0 "$pid" 2>/dev/null
}

sf_vm_pid() {
    cat "$SF_PID_FILE" 2>/dev/null || echo "—"
}

sf_vm_uptime() {
    local pid; pid=$(cat "$SF_PID_FILE" 2>/dev/null) || { echo "—"; return; }
    local start; start=$(ps -o lstart= -p "$pid" 2>/dev/null) || { echo "—"; return; }
    # uptime w formacie HH:MM:SS
    local secs; secs=$(( $(date +%s) - $(date -d "$start" +%s 2>/dev/null || echo 0) ))
    printf "%02d:%02d:%02d" $((secs/3600)) $(( (secs%3600)/60 )) $((secs%60))
}

sf_ros_boot_ready() {
    # RouterOS uważa się za gotowy gdy SSH odpowiada
    nc -z 127.0.0.1 "$PORT_SSH" 2>/dev/null
}

sf_port_in_use() {
    nc -z 127.0.0.1 "$1" 2>/dev/null
}

sf_relay_running() {
    pgrep -f "msmtpd.*${PORT_SMTP_RELAY}" >/dev/null 2>&1
}

sf_mem_free_mb() {
    awk '/MemAvailable/{printf "%d", $2/1024}' /proc/meminfo 2>/dev/null || echo "?"
}

sf_disk_free_mb() {
    df "$HOME" 2>/dev/null | awk 'NR==2{printf "%d", $4/1024}'
}

sf_disk_img_size() {
    [[ -f "$VM_DISK" ]] && du -sh "$VM_DISK" | cut -f1 || echo "—"
}

# ─────────────────────────── BANNER / DASHBOARD ──────────────────────────────
sf_banner() {
    clear
    local vm_status vm_col vm_pid vm_up
    local boot_status boot_col
    local relay_status relay_col
    local ssh_dot winbox_dot smtp_in_dot smtp_relay_dot

    if sf_vm_running; then
        vm_status="RUNNING"; vm_col="$GRN"
        vm_pid=$(sf_vm_pid); vm_up=$(sf_vm_uptime)
        if sf_ros_boot_ready; then
            boot_status="RouterOS gotowy"; boot_col="$GRN"
        else
            boot_status="Boot w toku..."; boot_col="$YLW"
        fi
    else
        vm_status="ZATRZYMANA"; vm_col="$RED"
        vm_pid="—"; vm_up="—"
        boot_status="VM offline"; boot_col="$D"
    fi

    sf_relay_running && { relay_status="● AKTYWNY"; relay_col="$GRN"; } \
                     || { relay_status="○ WYŁĄCZONY"; relay_col="$YLW"; }

    _dot() { sf_port_in_use "$1" && echo -e "${GRN}●${R}" || echo -e "${D}○${R}"; }
    ssh_dot=$(      _dot "$PORT_SSH")
    winbox_dot=$(   _dot "$PORT_WINBOX")
    smtp_in_dot=$(  _dot "$PORT_SMTP_IN")
    smtp_relay_dot=$( sf_relay_running && echo -e "${GRN}●${R}" || echo -e "${RED}○${R}" )

    echo -e "${CYN}${B}"
    echo "  ╔═══════════════════════════════════════════════════════════════╗"
    echo "  ║       SecFerro v2.0  ·  RouterOS on Termux/QEMU              ║"
    echo "  ╠═══════════════════════════════════════════════════════════════╣"
    printf "  ║  VM:     ${vm_col}%-10s${CYN}  PID:%-6s  Uptime: %-10s   ║\n" \
           "$vm_status" "$vm_pid" "$vm_up"
    printf "  ║  Boot:   ${boot_col}%-47s${CYN}  ║\n" "$boot_status"
    printf "  ║  Relay:  ${relay_col}%-47s${CYN}  ║\n" "$relay_status"
    echo "  ╠═══════════════════════════════════════════════════════════════╣"
    echo -e "  ║  Porty:  ${ssh_dot} 2222/SSH  ${smtp_in_dot} 2525/SMTP-in                      ${CYN}${B}║"
    echo -e "  ║          ${winbox_dot} 8291/Winbox ${smtp_relay_dot} 2526/SMTP-relay                ${CYN}${B}║"
    echo "  ╠═══════════════════════════════════════════════════════════════╣"
    printf "  ║  RAM:  %-8s MB free  │  Dysk: %-8s MB free  │  VM: %-5s  ║\n" \
           "$(sf_mem_free_mb)" "$(sf_disk_free_mb)" "$(sf_disk_img_size)"
    echo "  ╚═══════════════════════════════════════════════════════════════╝"
    echo -e "${R}"
}

# ─────────────────────────── MENU GŁÓWNE ─────────────────────────────────────
sf_menu() {
    while true; do
        sf_banner
        echo -e "${B}  MENU GŁÓWNE${R}"
        echo -e "  ${GRN}${B}1.${R} VM Management      (start/stop/restart/konsola)"
        echo -e "  ${GRN}${B}2.${R} RouterOS Config    (SSH quick-cmds, eksport, init)"
        echo -e "  ${YLW}${B}3.${R} SMTP / Email       (relay setup, test maila, status)"
        echo -e "  ${BLU}${B}4.${R} Sieć & DNS         (diagnostyka, ping, port-scan)"
        echo -e "  ${MAG}${B}5.${R} Security Scan      (sftest, netwatch, SNMP audit)"
        echo -e "  ${CYN}${B}6.${R} Logi               (QEMU, email, system)"
        echo -e "  ${D}${B}7.${R} Backup & Eksport   (config RouterOS, snapshot VM)"
        echo -e "  ${YLW}${B}8.${R} Konfiguracja       (ustawienia SecFerro)"
        echo -e "  ${RED}${B}0.${R} Wyjście"
        echo
        read -rp "  $(echo -e "${CYN}${B}Wybór [0-8] > ${R}")" ch
        case "$ch" in
            1) sf_menu_vm ;;
            2) sf_menu_ros ;;
            3) sf_menu_smtp ;;
            4) sf_menu_net ;;
            5) sf_menu_security ;;
            6) sf_menu_logs ;;
            7) sf_menu_backup ;;
            8) sf_menu_config ;;
            0) echo -e "\n${D}SecFerro zakończony.${R}\n"; exit 0 ;;
            *) c_warn "Nieznana opcja: '$ch'" ;;
        esac
        echo; read -rp "  $(echo -e "${D}Enter aby kontynuować...${R}")"
    done
}

# ─────────────────────────── MENU: VM ────────────────────────────────────────
sf_menu_vm() {
    c_hdr "VM MANAGEMENT — RouterOS QEMU TCG"
    echo -e "  ${GRN}${B}1.${R} Uruchom VM (sfstart)"
    echo -e "  ${RED}${B}2.${R} Zatrzymaj VM (sfstop)"
    echo -e "  ${YLW}${B}3.${R} Restart VM"
    echo -e "  ${BLU}${B}4.${R} Status szczegółowy"
    echo -e "  ${CYN}${B}5.${R} Konsola QEMU (monitor)"
    echo -e "  ${MAG}${B}6.${R} Czekaj na boot RouterOS"
    echo -e "  ${D}${B}0.${R} Wróć"
    echo
    read -rp "  $(echo -e "${CYN}Wybór > ${R}")" ch
    case "$ch" in
        1) sfstart ;;
        2) sfstop ;;
        3) sfstop; sleep 3; sfstart ;;
        4) sf_vm_status_detail ;;
        5) sf_qemu_monitor ;;
        6) sf_wait_boot ;;
        0) return ;;
    esac
}

sf_vm_status_detail() {
    c_hdr "STATUS VM — szczegółowy"
    if sf_vm_running; then
        local pid; pid=$(sf_vm_pid)
        c_ok "VM uruchomiona (PID: $pid)"
        c_dim "Uptime: $(sf_vm_uptime)"
        c_dim "RAM VM: ${VM_RAM}MB"
        c_dim "Obraz: $VM_DISK ($(sf_disk_img_size))"

        echo
        c_info "Procesy QEMU:"
        ps -p "$pid" -o pid,vsz,rss,pcpu,comm 2>/dev/null | head -5 | sed 's/^/    /'

        echo
        c_info "Porty sieciowe (przekierowania):"
        for p in "$PORT_SSH" "$PORT_SMTP_IN" "$PORT_SMTP_RELAY" "$PORT_WINBOX"; do
            if sf_port_in_use "$p"; then
                c_ok "Port $p — otwarty"
            else
                c_warn "Port $p — zamknięty"
            fi
        done

        echo
        if sf_ros_boot_ready; then
            c_ok "RouterOS SSH (port $PORT_SSH) — gotowy"
            # Quick system info via SSH
            local ros_ver
            ros_ver=$(timeout 5 ssh -o StrictHostKeyChecking=no \
                      -o ConnectTimeout=3 -p "$PORT_SSH" \
                      "${ROS_USER}@127.0.0.1" \
                      "/system resource print interval=0" 2>/dev/null | head -20 || true)
            [[ -n "$ros_ver" ]] && echo "$ros_ver" | head -15 | sed 's/^/    /'
        else
            c_warn "RouterOS SSH — niedostępny (VM może być w trakcie bootu)"
        fi
    else
        c_err "VM nie działa"
        c_dim "Uruchom przez opcję 1 lub komendą: sfstart"
    fi
}

sf_wait_boot() {
    c_hdr "CZEKAM NA BOOT ROUTEROS"
    c_info "Oczekiwanie na SSH (port $PORT_SSH)..."
    local timeout=120; local elapsed=0
    while ! sf_ros_boot_ready; do
        printf "\r  ${YLW}Czekam... %3ds / %3ds${R}" "$elapsed" "$timeout"
        sleep 3; elapsed=$((elapsed+3))
        [[ $elapsed -ge $timeout ]] && { echo; c_err "Timeout — RouterOS nie odpalił w ${timeout}s"; return 1; }
    done
    echo
    c_ok "RouterOS gotowy po ${elapsed}s!"
}

sf_qemu_monitor() {
    c_hdr "QEMU MONITOR — konsola"
    local sock="${SF_HOME}/run/qemu-monitor.sock"
    if [[ -S "$sock" ]]; then
        c_info "Łączę z QEMU monitor (Ctrl+C żeby wyjść)..."
        echo -e "${D}Wpisz 'quit' żeby zamknąć VM, 'info status' żeby sprawdzić stan${R}"
        socat - "UNIX-CONNECT:$sock" 2>/dev/null || c_err "socat niedostępny — zainstaluj: pkg install socat"
    else
        c_err "Monitor socket nie istnieje: $sock"
        c_dim "Uruchom VM z opcją monitoringu (sfstart)"
    fi
}

# ─────────────────────────── MENU: ROUTEROS ──────────────────────────────────
sf_menu_ros() {
    c_hdr "ROUTEROS CONFIG — quick commands"
    echo -e "  ${GRN}${B}1.${R} SSH → RouterOS (interaktywna sesja)"
    echo -e "  ${BLU}${B}2.${R} Eksport konfiguracji RouterOS"
    echo -e "  ${YLW}${B}3.${R} Wyślij skrypt init (init.rsc)"
    echo -e "  ${MAG}${B}4.${R} Skonfiguruj email RouterOS (SMTP relay)"
    echo -e "  ${CYN}${B}5.${R} Pokaż zasoby systemowe RouterOS"
    echo -e "  ${GRN}${B}6.${R} Pokaż interfejsy sieciowe RouterOS"
    echo -e "  ${YLW}${B}7.${R} Netwatch — dodaj reguły monitorowania"
    echo -e "  ${D}${B}8.${R} Wyślij dowolną komendę RouterOS"
    echo -e "  ${D}${B}0.${R} Wróć"
    echo
    read -rp "  $(echo -e "${CYN}Wybór > ${R}")" ch
    case "$ch" in
        1) sf_ros_ssh ;;
        2) sf_ros_export_config ;;
        3) sf_ros_send_init ;;
        4) sf_ros_configure_email ;;
        5) sf_ros_cmd "/system resource print" ;;
        6) sf_ros_cmd "/interface print" ;;
        7) sf_ros_netwatch_setup ;;
        8) read -rp "  Komenda RouterOS > " cmd; sf_ros_cmd "$cmd" ;;
        0) return ;;
    esac
}

sf_ros_ssh() {
    if ! sf_ros_boot_ready; then
        c_err "RouterOS SSH niedostępny. Sprawdź czy VM działa."
        return 1
    fi
    c_info "Łączę z RouterOS SSH (127.0.0.1:$PORT_SSH)..."
    echo -e "${D}(Użyj 'quit' lub Ctrl+D żeby wyjść z RouterOS)${R}"
    ssh -o StrictHostKeyChecking=no \
        -o ConnectTimeout=5 \
        -o ServerAliveInterval=30 \
        -p "$PORT_SSH" \
        "${ROS_USER}@127.0.0.1"
}

sf_ros_cmd() {
    local cmd="$1"
    if ! sf_ros_boot_ready; then
        c_err "RouterOS niedostępny"
        return 1
    fi
    c_info "Komenda: $cmd"
    timeout 15 ssh -o StrictHostKeyChecking=no -o ConnectTimeout=5 \
        -p "$PORT_SSH" "${ROS_USER}@127.0.0.1" "$cmd" 2>/dev/null || true
}

sf_ros_export_config() {
    c_hdr "EKSPORT KONFIGURACJI ROUTEROS"
    local ts; ts=$(date +%Y%m%d_%H%M%S)
    local out_file="${SF_HOME}/backups/ros_config_${ts}.rsc"
    mkdir -p "${SF_HOME}/backups"
    c_info "Eksportuję konfigurację..."
    if sf_ros_cmd "/export" > "$out_file" 2>&1; then
        c_ok "Konfiguracja zapisana: $out_file"
        c_dim "$(wc -l < "$out_file") linii"
    else
        c_err "Błąd eksportu"
    fi
}

sf_ros_send_init() {
    c_hdr "WYSYŁAM init.rsc → ROUTEROS"
    local init_rsc="${SF_HOME}/conf/init.rsc"
    if [[ ! -f "$init_rsc" ]]; then
        c_err "Brak pliku: $init_rsc"
        c_dim "Wygeneruj go przez: Konfiguracja → Generuj init.rsc"
        return 1
    fi
    c_info "Kopiuję $init_rsc na RouterOS..."
    scp -o StrictHostKeyChecking=no -P "$PORT_SSH" \
        "$init_rsc" "${ROS_USER}@127.0.0.1:/init_upload.rsc" 2>/dev/null || {
        c_err "scp nie zadziałał — próbuję przez SSH here-doc..."
        cat "$init_rsc" | ssh -o StrictHostKeyChecking=no -p "$PORT_SSH" \
            "${ROS_USER}@127.0.0.1" "import file-name=init_upload.rsc" 2>/dev/null || true
        return
    }
    c_ok "Skopiowano. Uruchamiam..."
    sf_ros_cmd "/import file-name=init_upload.rsc"
    c_ok "init.rsc wykonany ✓"
}

sf_ros_configure_email() {
    c_hdr "KONFIGURACJA EMAIL ROUTEROS"
    c_info "Ustawiam RouterOS /tool e-mail → relay na 192.168.168.1:25 (guestfwd)"
    echo
    c_warn "Relay działa TYLKO gdy VM uruchomiona z guestfwd=tcp:192.168.168.1:25→127.0.0.1:2526"
    c_warn "Używaj 'sfstart' — automatycznie dodaje guestfwd"
    echo

    local ros_email_cmds
    ros_email_cmds="$(cat <<'EOF'
/tool e-mail
set address=192.168.168.1
set port=25
set start-tls=no
set user=router
set password=secferro
set from=router@secferro.lan
EOF
)"
    echo "$ros_email_cmds" | sf_ros_cmd "/import from-stdin" 2>/dev/null || {
        # Fallback: wyślij linia po linii
        sf_ros_cmd "/tool e-mail set address=192.168.168.1 port=25 start-tls=no from=router@secferro.lan user=router password=secferro"
    }
    c_ok "RouterOS email skonfigurowany → 192.168.168.1:25"
    c_dim "Testuj: sfmail test"
}

sf_ros_netwatch_setup() {
    c_hdr "NETWATCH — reguły monitorowania"
    c_info "Dodaję netwatch dla 8.8.8.8 (Google DNS)"
    sf_ros_cmd "/tool netwatch add host=8.8.8.8 interval=1m \
        up-script=\"/log info message=\\\"8.8.8.8 UP\\\"\" \
        down-script=\"/log warning message=\\\"8.8.8.8 DOWN - brak internetu!\\\"\""
    c_ok "Netwatch dodany ✓"
    sf_ros_cmd "/tool netwatch print"
}

# ─────────────────────────── MENU: SMTP ──────────────────────────────────────
