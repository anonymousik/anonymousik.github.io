sf_ping_vm() {
    c_info "Ping 127.0.0.1:$PORT_SSH (portforward test)..."
    # RouterOS na QEMU user-network nie jest bezpośrednio pingable z hosta
    # Testujemy przez port TCP zamiast ICMP
    if nc -z -w3 127.0.0.1 "$PORT_SSH" 2>/dev/null; then
        c_ok "RouterOS SSH port ($PORT_SSH) — osiągalny ✓"
    else
        c_err "RouterOS SSH port ($PORT_SSH) — niedostępny"
        c_dim "VM może być wyłączona lub w trakcie bootu"
    fi
    for p in "$PORT_SMTP_IN" "$PORT_WINBOX"; do
        nc -z -w2 127.0.0.1 "$p" 2>/dev/null && c_ok "Port $p — OK" || c_warn "Port $p — zamknięty"
    done
}

sf_scan_local_ports() {
    c_hdr "SKAN PORTÓW LOCALHOST"
    local ports=(22 25 80 443 2222 2525 2526 8080 8291 8728)
    c_info "Sprawdzam ${#ports[@]} portów..."
    for p in "${ports[@]}"; do
        if nc -z -w1 127.0.0.1 "$p" 2>/dev/null; then
            printf "  ${GRN}●${R} %-5s — otwarty\n" "$p"
        else
            printf "  ${D}○${R} %-5s — zamknięty\n" "$p"
        fi
    done
}

sf_fix_hosts() {
    c_hdr "NAPRAWA /etc/hosts"
    # Problem z sesji: emu.secferro.lan rozwiązuje na 192.168.168.168 ale ping failuje
    # Powinno wskazywać na 192.168.168.1 (gateway QEMU) lub 127.0.0.1 (tunnel)
    # Ponieważ RouterOS jest dostępny przez porty na 127.0.0.1, ta jest najlepsza

    local hosts_file="/data/data/com.termux/files/usr/etc/hosts"
    [[ ! -f "$hosts_file" ]] && hosts_file="/etc/hosts"

    c_info "Aktualny stan dns dla *.secferro.lan:"
    grep -i "secferro" "$hosts_file" 2>/dev/null || echo "  (brak wpisów)"
    echo

    echo -e "  ${D}QEMU user-net: RouterOS dostępny przez 127.0.0.1 (portforward)${R}"
    echo -e "  ${D}ICMP ping do 192.168.168.x z hosta nie działa (slirp — normal)${R}"
    echo
    echo -e "  ${YLW}Nowe wpisy które zostaną dodane:${R}"
    echo "  127.0.0.1  emu.secferro.lan  router.secferro.lan"
    echo "  127.0.0.1  routeros.secferro.lan"
    echo
    read -rp "  $(echo -e "${CYN}Zastosować? [T/n] > ${R}")" ans
    [[ "${ans,,}" == "n" ]] && return

    # Usuń stare wpisy secferro.lan
    sed -i '/secferro\.lan/d' "$hosts_file" 2>/dev/null || true
    # Dodaj nowe
    cat >> "$hosts_file" <<EOF
# SecFerro v2 — RouterOS VM (QEMU user-network)
# RouterOS dostępny przez port-forwards na 127.0.0.1
127.0.0.1  emu.secferro.lan router.secferro.lan routeros.secferro.lan
EOF
    c_ok "/etc/hosts zaktualizowany"
    c_info "Test:"
    ping -c 2 emu.secferro.lan 2>/dev/null || nc -z -w2 emu.secferro.lan "$PORT_SSH" 2>/dev/null \
        && c_ok "emu.secferro.lan osiągalny" || c_warn "Nadal problem (normalny na slirp — użyj portforwards)"
}

sf_net_report_full() {
    c_hdr "PEŁNY RAPORT SIECI"
    echo -e "${B}── Interfejsy ──${R}"
    ip addr 2>/dev/null | grep -E "(^[0-9]|inet )" | sed 's/^/  /'
    echo
    echo -e "${B}── Trasy ──${R}"
    ip route 2>/dev/null | sed 's/^/  /'
    echo
    echo -e "${B}── DNS ──${R}"
    cat /etc/resolv.conf 2>/dev/null | sed 's/^/  /'
    echo
    echo -e "${B}── Porty VM (forwards) ──${R}"
    sf_scan_local_ports
    echo
    echo -e "${B}── Relay SMTP ──${R}"
    sf_relay_running && c_ok "msmtpd relay aktywny (:$PORT_SMTP_RELAY)" || c_warn "Relay wyłączony"
}

