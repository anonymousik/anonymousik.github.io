    echo
    read -rp "  $(echo -e "${CYN}Wybór > ${R}")" ch
    case "$ch" in
        1) sf_ros_export_config ;;
        2) sf_ros_backup_binary ;;
        3) ls -lht "${SF_HOME}/backups/" 2>/dev/null || c_warn "Brak backupów" ;;
        4) sf_ros_restore_rsc ;;
