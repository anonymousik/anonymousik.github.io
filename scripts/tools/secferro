sf_ros_backup_binary() {
    local ts; ts=$(date +%Y%m%d_%H%M%S)
    local name="secferro_backup_${ts}"
    c_info "Tworzę backup binarny: $name"
    sf_ros_cmd "/system backup save name=$name"
    c_ok "Backup utworzony na RouterOS: $name.backup"
    c_dim "Pobierz przez SCP: scp -P $PORT_SSH ${ROS_USER}@127.0.0.1:/${name}.backup ${SF_HOME}/backups/"
}

sf_ros_restore_rsc() {
    c_hdr "PRZYWRÓĆ KONFIGURACJĘ"
    local bdir="${SF_HOME}/backups"
    ls -1 "$bdir"/*.rsc 2>/dev/null || { c_warn "Brak plików .rsc w $bdir"; return; }
    echo
    read -rp "  Podaj pełną ścieżkę do pliku .rsc: " rsc_file
    [[ -f "$rsc_file" ]] || { c_err "Plik nie istnieje: $rsc_file"; return; }
    c_warn "UWAGA: to NADPISZE bieżącą konfigurację RouterOS!"
    read -rp "  Jesteś pewny? [wpisz POTWIERDŹ]: " conf
    [[ "$conf" == "POTWIERDŹ" ]] || { c_info "Anulowano."; return; }
    scp -o StrictHostKeyChecking=no -P "$PORT_SSH" \
        "$rsc_file" "${ROS_USER}@127.0.0.1:/restore.rsc" 2>/dev/null
    sf_ros_cmd "/import file-name=restore.rsc"
    c_ok "Konfiguracja przywrócona"
}

