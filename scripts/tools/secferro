    echo -e "  ${YLW}${B}6.${R} Sprawdź trasy sieciowe"
    echo -e "  ${MAG}${B}7.${R} Traceroute do 8.8.8.8"
    echo -e "  ${CYN}${B}8.${R} Pełny raport sieci"
    echo -e "  ${D}${B}0.${R} Wróć"
    echo
    read -rp "  $(echo -e "${CYN}Wybór > ${R}")" ch
    case "$ch" in
        1) sf_ping_vm ;;
