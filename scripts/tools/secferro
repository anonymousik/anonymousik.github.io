sf_sec_snmp_audit() {
    c_hdr "AUDYT SNMP ROUTEROS"
    local status; status=$(sf_ros_cmd "/snmp print interval=0" 2>/dev/null || echo "ERROR")
    echo "$status" | sed 's/^/  /'
    echo
    # Sprawdź czy SNMP jest włączone i czy community jest domyślne
    if echo "$status" | grep -q "enabled: yes"; then
        c_warn "SNMP jest WŁĄCZONE"
        if echo "$status" | grep -q "community: public"; then
            c_err "Community 'public' — domyślne, ZMIEŃ!"
        fi
    else
        c_ok "SNMP wyłączone ✓"
    fi
}

sf_sec_user_audit() {
    c_hdr "AUDYT KONT UŻYTKOWNIKÓW"
    sf_ros_cmd "/user print"
    echo
    c_info "Grupy uprawnień:"
    sf_ros_cmd "/user group print"
}

sf_sec_check_updates() {
    c_hdr "SPRAWDZAM AKTUALIZACJE ROUTEROS"
    sf_ros_cmd "/system package update check-for-updates"
}

sf_sec_port_scan_vm() {
    c_hdr "SKAN PORTÓW VM (nmap/nc)"
    c_info "Skanowanie portów RouterOS przez localhost..."
    if command -v nmap >/dev/null 2>&1; then
        nmap -p 1-9999 -T4 --open 127.0.0.1 2>/dev/null | tail -30
    else
        c_warn "nmap niedostępny — używam nc (wolniejszy)"
        local open=()
        for p in 22 23 80 443 2222 2525 8291 8728 8729; do
            nc -z -w1 127.0.0.1 "$p" 2>/dev/null && open+=("$p")
        done
        c_info "Otwarte porty: ${open[*]:-brak znalezionych}"
    fi
}

sf_sec_firewall_audit() {
    c_hdr "FIREWALL AUDIT ROUTEROS"
    c_info "Reguły filter:"
    sf_ros_cmd "/ip firewall filter print"
    echo
    c_info "Reguły NAT:"
    sf_ros_cmd "/ip firewall nat print"
    echo
    c_info "Connection tracking:"
    sf_ros_cmd "/ip firewall connection print count-only"
}

