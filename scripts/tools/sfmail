#!/data/data/com.termux/files/usr/bin/bash
# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  sfmail — SecFerro SMTP Relay Manager                                   ║
# ║                                                                          ║
# ║  Architektura:                                                          ║
# ║    RouterOS VM → 192.168.168.1:25 (guestfwd) → msmtpd:2526           ║
# ║    msmtpd → msmtp → Gmail/SMTP zewnętrzny                             ║
# ║                                                                          ║
# ║  Problem w poprzedniej sesji:                                           ║
# ║    • msmtpd nasłuchiwał na :2525 (ZAJĘTY — hostfwd dla VM port 25)    ║
# ║    • msmtp --rmqs nie jest do tego — to Remote MQ Starting             ║
# ║    • Poprawka: msmtpd na :2526 + guestfwd w QEMU →  192.168.1.1:25   ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
set -euo pipefail

SF_HOME="${SF_HOME:-$HOME/secferro}"
SF_CONF="${SF_HOME}/conf/secferro.conf"
[[ -f "$SF_CONF" ]] && source "$SF_CONF"

: "${PORT_SMTP_RELAY:=2526}"
: "${PORT_SSH:=2222}"
: "${ROS_USER:=admin}"
: "${MAIL_FROM:=router@secferro.lan}"
: "${MAIL_ALERT_TO:=}"
: "${NET_HOST_GW:=192.168.168.1}"

LOG_DIR="${SF_HOME}/logs"
RELAY_LOG="${LOG_DIR}/sfmail_relay.log"
RELAY_PID_FILE="${SF_HOME}/run/msmtpd.pid"
MSMTPRC="$HOME/.msmtprc"

R='\033[0m'; B='\033[1m'; D='\033[2m'
GRN='\033[92m'; RED='\033[91m'; YLW='\033[93m'
BLU='\033[94m'; CYN='\033[96m'; MAG='\033[95m'

ok()   { echo -e "${GRN}${B}[✓]${R} $*"; }
err()  { echo -e "${RED}${B}[✗]${R} $*"; }
warn() { echo -e "${YLW}${B}[!]${R} $*"; }
info() { echo -e "${CYN}[i]${R} $*"; }
hdr()  { echo -e "\n${CYN}${B}── $* ──${R}\n"; }

mkdir -p "$LOG_DIR" "${SF_HOME}/run"

# ─────────────────────────────────────────────────────────────────────────────
_relay_running() {
    [[ -f "$RELAY_PID_FILE" ]] || return 1
    local pid; pid=$(cat "$RELAY_PID_FILE" 2>/dev/null) || return 1
    kill -0 "$pid" 2>/dev/null
}

_relay_pid() { cat "$RELAY_PID_FILE" 2>/dev/null || echo "—"; }

_check_msmtp() {
    if ! command -v msmtp >/dev/null 2>&1; then
        err "msmtp niedostępny. Zainstaluj: pkg install msmtp"
        return 1
    fi
    if ! command -v msmtpd >/dev/null 2>&1; then
        err "msmtpd niedostępny. Zainstaluj: pkg install msmtp"
        return 1
    fi
    return 0
}

_check_config() {
    if [[ ! -f "$MSMTPRC" ]]; then
        err "Brak konfiguracji ~/.msmtprc"
        echo -e "  ${D}Skonfiguruj przez: secferro → SMTP → Konfiguruj dane konta${R}"
        echo -e "  ${D}Lub uruchom:       sfmail configure${R}"
        return 1
    fi
    if grep -q "YOUR_PASSWORD\|PLACEHOLDER\|example\.com" "$MSMTPRC" 2>/dev/null; then
        warn ".msmtprc zawiera dane placeholder — uzupełnij prawdziwe dane"
        return 1
    fi
    return 0
}

# ─────────────────────────────────────────────────────────────────────────────
# CMD: start
# ─────────────────────────────────────────────────────────────────────────────
cmd_start() {
    hdr "SMTP RELAY — Start"

    if _relay_running; then
        ok "Relay już działa (PID: $(_relay_pid), port: $PORT_SMTP_RELAY)"
        return 0
    fi

    _check_msmtp    || exit 1
    _check_config   || exit 1

    # Sprawdź czy port jest wolny
    if nc -z 127.0.0.1 "$PORT_SMTP_RELAY" 2>/dev/null; then
        err "Port $PORT_SMTP_RELAY zajęty przez inny proces"
        echo -e "  ${D}Sprawdź: lsof -i :${PORT_SMTP_RELAY}${R}"
        exit 1
    fi

    info "Uruchamiam msmtpd na 127.0.0.1:${PORT_SMTP_RELAY}..."
    info "Konfiguracja: $MSMTPRC"
    info "Log: $RELAY_LOG"

    # msmtpd jako daemon (background)
    # --command: każdy mail wchodzący przez relay → msmtp go wysyła dalej
    # --interface: słuchaj TYLKO na localhost (nie na zewnątrz)
    # --port: 2526 (nie 25 — Termux nie może bindować portów < 1024)
    # --log: loguj do pliku
    nohup msmtpd \
        --interface=127.0.0.1 \
        --port="$PORT_SMTP_RELAY" \
        --log="$RELAY_LOG" \
        --command="msmtp --host=\$(cat $MSMTPRC | grep '^host' | head -1 | awk '{print \$2}') -f %F -- %T" \
        </dev/null >>"$RELAY_LOG" 2>&1 &

    RELAY_PID=$!
    echo "$RELAY_PID" > "$RELAY_PID_FILE"

    sleep 2

    if ! kill -0 "$RELAY_PID" 2>/dev/null; then
        err "msmtpd zakończył się natychmiast. Log:"
        tail -10 "$RELAY_LOG" 2>/dev/null | sed 's/^/  /' || true
        rm -f "$RELAY_PID_FILE"
        exit 1
    fi

    ok "SMTP relay uruchomiony (PID: $RELAY_PID)"
    echo
    echo -e "  ${B}Routing:${R}"
    echo -e "    RouterOS (VM) → ${CYN}${NET_HOST_GW}:25${R}"
    echo -e "    QEMU guestfwd → ${CYN}127.0.0.1:${PORT_SMTP_RELAY}${R}"
    echo -e "    msmtpd relay  → External SMTP (z .msmtprc)"
    echo
    echo -e "  ${D}RouterOS config: /tool e-mail set address=${NET_HOST_GW} port=25${R}"
}

# ─────────────────────────────────────────────────────────────────────────────
# CMD: stop
# ─────────────────────────────────────────────────────────────────────────────
cmd_stop() {
    hdr "SMTP RELAY — Stop"

    if ! _relay_running; then
        warn "Relay nie działa"
        rm -f "$RELAY_PID_FILE"
        return 0
    fi

    local pid; pid=$(_relay_pid)
    kill -TERM "$pid" 2>/dev/null || true
    sleep 1
    kill -0 "$pid" 2>/dev/null && kill -KILL "$pid" 2>/dev/null || true

    rm -f "$RELAY_PID_FILE"
    ok "SMTP relay zatrzymany (PID: $pid)"
}

# ─────────────────────────────────────────────────────────────────────────────
# CMD: status
# ─────────────────────────────────────────────────────────────────────────────
cmd_status() {
    hdr "SMTP RELAY — Status"

    if _relay_running; then
        ok "msmtpd AKTYWNY (PID: $(_relay_pid))"
        echo -e "   Port: ${CYN}127.0.0.1:${PORT_SMTP_RELAY}${R}"
        echo -e "   Log:  ${D}$RELAY_LOG${R}"
    else
        warn "msmtpd WYŁĄCZONY"
    fi

    echo
    info "Konfiguracja msmtp:"
    if [[ -f "$MSMTPRC" ]]; then
        grep -E "^(host|port|user|from|account)" "$MSMTPRC" 2>/dev/null \
            | grep -v "password" \
            | sed 's/^/  /'
        ok ".msmtprc istnieje ($(wc -l < "$MSMTPRC") linii)"
    else
        err ".msmtprc brak"
    fi

    echo
    info "Ostatnie logi:"
    [[ -f "$RELAY_LOG" ]] && tail -10 "$RELAY_LOG" | sed 's/^/  /' || echo "  (brak logów)"
}

# ─────────────────────────────────────────────────────────────────────────────
# CMD: test
# ─────────────────────────────────────────────────────────────────────────────
cmd_test() {
    hdr "TEST WYSYŁKI EMAIL"

    local test_to="${1:-$MAIL_ALERT_TO}"
    if [[ -z "$test_to" ]]; then
        read -rp "  Adres odbiorcy (np. admin@gmail.com): " test_to
        [[ -z "$test_to" ]] && { err "Brak adresu odbiorcy"; exit 1; }
    fi

    _check_msmtp  || exit 1
    _check_config || exit 1

    info "Test 1: msmtp --serverinfo"
    local host; host=$(grep "^host" "$MSMTPRC" | head -1 | awk '{print $2}' 2>/dev/null || echo "unknown")
    local port; port=$(grep "^port" "$MSMTPRC" | head -1 | awk '{print $2}' 2>/dev/null || echo "587")
    timeout 15 msmtp --file="$MSMTPRC" --account=secferro-relay \
        --serverinfo 2>&1 | head -15 | sed 's/^/  /' || warn "serverinfo failed (może być OK)"

    echo
    info "Test 2: Wysyłam testowy email na $test_to..."

    local subject="[SecFerro] Test maila $(date '+%Y-%m-%d %H:%M')"
    local body
    body=$(cat <<EOF
SecFerro v2.0 — Test Wysyłki

Data:     $(date)
Host:     $(hostname 2>/dev/null || echo "android")
VM:       RouterOS @ 127.0.0.1:${PORT_SSH}
Relay:    127.0.0.1:${PORT_SMTP_RELAY} → ${host}:${port}

Jeśli widzisz tę wiadomość — SMTP relay działa poprawnie!

--
SecFerro v2.0 / Termux
EOF
)

    if echo "$body" | msmtp \
        --file="$MSMTPRC" \
        --account=secferro-relay \
        --from="$MAIL_FROM" \
        --read-envelope-from \
        -- "$test_to" 2>&1; then
        ok "Email wysłany do: $test_to"
    else
        err "Błąd wysyłki — sprawdź logi: $RELAY_LOG"
        echo
        info "Weryfikacja krok po kroku:"
        _diagnose_smtp
    fi

    echo
    info "Test 3: Wysyłka przez RouterOS (jeśli VM działa)..."
    if nc -z -w2 127.0.0.1 "$PORT_SSH" 2>/dev/null; then
        timeout 15 ssh \
            -o StrictHostKeyChecking=no -o ConnectTimeout=3 \
            -p "$PORT_SSH" "${ROS_USER:-admin}@127.0.0.1" \
            "/tool e-mail send to=\"$test_to\" subject=\"[RouterOS] Test\" body=\"SecFerro test z RouterOS\"" \
            2>/dev/null && ok "RouterOS email wysłany!" || warn "RouterOS email failed"
    else
        info "RouterOS SSH niedostępny — pominam test VM"
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# CMD: debug
# ─────────────────────────────────────────────────────────────────────────────
cmd_debug() {
    hdr "DEBUG SMTP RELAY — diagnostyka krok po kroku"

    _check_msmtp || exit 1

    info "1. Wersja msmtp:"
    msmtp --version 2>&1 | head -3 | sed 's/^/   /'

    echo
    info "2. Konfiguracja (bez hasła):"
    [[ -f "$MSMTPRC" ]] \
        && sed 's/^password.*/password [UKRYTE]/' "$MSMTPRC" | sed 's/^/   /' \
        || err "Brak ~/.msmtprc"

    echo
    info "3. Porty SMTP (sprawdzam):"
    for p in 25 465 587 2525 2526; do
        nc -z -w2 127.0.0.1 "$p" 2>/dev/null \
            && echo -e "   ${GRN}●${R} 127.0.0.1:$p — otwarty" \
            || echo -e "   ${D}○${R} 127.0.0.1:$p — zamknięty"
    done

    echo
    info "4. Verbose test msmtp:"
    local host; host=$(grep "^host" "$MSMTPRC" 2>/dev/null | head -1 | awk '{print $2}' || echo "smtp.gmail.com")
    local port; port=$(grep "^port" "$MSMTPRC" 2>/dev/null | head -1 | awk '{print $2}' || echo "587")
    timeout 15 msmtp --file="$MSMTPRC" --debug --serverinfo 2>&1 | sed 's/^/   /' || true

    echo
    info "5. Test TCP connect do serwera SMTP:"
    nc -z -w5 "$host" "$port" 2>/dev/null \
        && ok "$host:$port — osiągalny ✓" \
        || err "$host:$port — niedostępny (firewall? brak internetu?)"

    _diagnose_smtp
}

_diagnose_smtp() {
    echo
    info "Diagnoza najczęstszych problemów:"
    local host; host=$(grep "^host" "$MSMTPRC" 2>/dev/null | head -1 | awk '{print $2}' || echo "")
    local user; user=$(grep "^user" "$MSMTPRC" 2>/dev/null | head -1 | awk '{print $2}' || echo "")

    [[ -z "$host" ]] && { err "Brak 'host' w .msmtprc → uruchom: sfmail configure"; return; }
    [[ -z "$user" ]] && { err "Brak 'user' w .msmtprc → uzupełnij dane konta"; return; }

    if [[ "$host" == *"gmail"* ]]; then
        echo -e "  ${YLW}Dla Gmail:${R}"
        echo "    • Włącz 2FA na koncie Google"
        echo "    • Wygeneruj App Password: https://myaccount.google.com/apppasswords"
        echo "    • Użyj App Password (16 znaków) jako hasła w .msmtprc"
        echo "    • Ustaw user = pełny adres Gmail (np. user@gmail.com)"
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# CMD: configure
# ─────────────────────────────────────────────────────────────────────────────
cmd_configure() {
    hdr "KONFIGURACJA SMTP"
    echo -e "  ${D}Wygeneruje ~/.msmtprc na podstawie podanych danych${R}"
    echo

    read -rp "  SMTP host [smtp.gmail.com]: " SMTP_HOST
    SMTP_HOST="${SMTP_HOST:-smtp.gmail.com}"

    read -rp "  SMTP port [587]: " SMTP_PORT
    SMTP_PORT="${SMTP_PORT:-587}"

    read -rp "  Email/user: " SMTP_USER
    [[ -z "$SMTP_USER" ]] && { err "Wymagany adres email"; exit 1; }

    read -rsp "  Hasło (ukryte — dla Gmail użyj App Password): " SMTP_PASS; echo
    [[ -z "$SMTP_PASS" ]] && { err "Hasło wymagane"; exit 1; }

    read -rp "  From address [${SMTP_USER}]: " SMTP_FROM
    SMTP_FROM="${SMTP_FROM:-$SMTP_USER}"

    read -rp "  Alert TO (odbiorca testów): " ALERT_TO

    # TLS mode na podstawie portu
    local tls_on="on"; local starttls="on"
    [[ "$SMTP_PORT" == "465" ]] && tls_on="on" && starttls="off"
    [[ "$SMTP_PORT" == "587" ]] && tls_on="on" && starttls="on"
    [[ "$SMTP_PORT" == "25"  ]] && tls_on="off" && starttls="off"

    cat > "$MSMTPRC" <<EOF
# ~/.msmtprc — wygenerowany przez SecFerro v2.0
# $(date)

defaults
    auth              on
    tls               ${tls_on}
    tls_starttls      ${starttls}
    tls_trust_file    /data/data/com.termux/files/usr/etc/tls/cert.pem
    tls_certcheck     on
    logfile           ${RELAY_LOG}

account secferro-relay
    host              ${SMTP_HOST}
    port              ${SMTP_PORT}
    from              ${SMTP_FROM}
    user              ${SMTP_USER}
    password          ${SMTP_PASS}

account alert
    host              ${SMTP_HOST}
    port              ${SMTP_PORT}
    from              ${SMTP_FROM}
    user              ${SMTP_USER}
    password          ${SMTP_PASS}

account default : secferro-relay
EOF
    chmod 600 "$MSMTPRC"

    # Zapisz MAIL_ALERT_TO do konfig SecFerro
    if [[ -n "$ALERT_TO" ]] && [[ -f "$SF_CONF" ]]; then
        sed -i "s|MAIL_ALERT_TO=.*|MAIL_ALERT_TO=\"${ALERT_TO}\"|" "$SF_CONF" 2>/dev/null || true
        echo "MAIL_ALERT_TO=\"${ALERT_TO}\"" >> "$SF_CONF"
    fi

    ok ".msmtprc zapisany (chmod 600)"
    echo
    read -rp "  Przetestować wysyłkę teraz? [T/n]: " ans
    [[ "${ans,,}" != "n" ]] && cmd_test "$ALERT_TO"
}

# ─────────────────────────────────────────────────────────────────────────────
# CMD: logs
# ─────────────────────────────────────────────────────────────────────────────
cmd_logs() {
    hdr "LOGI SMTP"
    if [[ -f "$RELAY_LOG" ]]; then
        echo -e "  ${D}Plik: $RELAY_LOG${R}\n"
        tail -50 "$RELAY_LOG" | sed 's/password=[^ ]*/password=[UKRYTE]/gi' | sed 's/^/  /'
    else
        warn "Brak pliku logu. Relay nie był jeszcze uruchamiany."
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# CMD: send (szybkie wysłanie alertu z Termux)
# ─────────────────────────────────────────────────────────────────────────────
cmd_send() {
    local to="${1:-$MAIL_ALERT_TO}"
    local subject="${2:-[SecFerro Alert]}"
    local body="${3:-Alert z SecFerro $(date)}"

    [[ -z "$to" ]] && { err "Brak odbiorcy. Użyj: sfmail send admin@gmail.com 'Temat' 'Treść'"; exit 1; }
    _check_msmtp  || exit 1
    _check_config || exit 1

    echo "$body" | msmtp \
        --file="$MSMTPRC" --account=alert \
        --subject="$subject" \
        --from="$MAIL_FROM" \
        -- "$to" 2>&1 \
        && ok "Email wysłany: $subject → $to" \
        || err "Błąd wysyłki — sprawdź: sfmail debug"
}

# ─────────────────────────────────────────────────────────────────────────────
# MAIN
# ─────────────────────────────────────────────────────────────────────────────
CMD="${1:-status}"
shift || true

case "$CMD" in
    start)      cmd_start ;;
    stop)       cmd_stop ;;
    restart)    cmd_stop; sleep 1; cmd_start ;;
    status)     cmd_status ;;
    test)       cmd_test "${1:-}" ;;
    debug)      cmd_debug ;;
    configure)  cmd_configure ;;
    logs|log)   cmd_logs ;;
    send)       cmd_send "${1:-}" "${2:-}" "${3:-}" ;;
    *)
        echo "sfmail — SecFerro SMTP Relay Manager"
        echo
        echo "Użycie:"
        echo "  sfmail start           — uruchom relay msmtpd na :${PORT_SMTP_RELAY}"
        echo "  sfmail stop            — zatrzymaj relay"
        echo "  sfmail restart         — restart relay"
        echo "  sfmail status          — pokaż status"
        echo "  sfmail test [email]    — wyślij testowy email"
        echo "  sfmail configure       — interaktywna konfiguracja .msmtprc"
        echo "  sfmail debug           — diagnoza krok po kroku"
        echo "  sfmail logs            — pokaż logi"
        echo "  sfmail send TO SUBJ BODY  — wyślij alert z CLI"
        ;;
esac
